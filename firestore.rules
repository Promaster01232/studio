rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Super Admin: Absolute authority check based on token email
    function isSuperAdmin() {
      return isAuthenticated() && 
             'email' in request.auth.token && 
             request.auth.token.email != null && (
        request.auth.token.email.lower() == 'enterspaceindia@gmail.com' || 
        request.auth.token.email.lower() == 'piyushkumrsingh23399@gmail.com' ||
        request.auth.token.email.lower() == 'nyayasahayakhelp@gmail.com'
      );
    }

    // General Admin check - Safer evaluation for query proving
    function isAdmin() {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true
      );
    }

    // GLOBAL ADMIN OVERRIDE: Absolute clearance for Root Nodes
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Users collection: Identity Registry
    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create: if isAuthenticated() && userId == request.auth.uid;
      allow update: if isAuthenticated() && (userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Notifications collection: Institutional Alerts
    match /notifications/{notificationId} {
      // Split owner and admin checks for query provability
      allow get, list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow get, list: if isAdmin();
      
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Transactions collection: Statutory Ledger
    match /transactions/{transactionId} {
      // Split owner and admin checks for query provability
      allow get, list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow get, list: if isAdmin();
      
      allow create: if isAuthenticated();
    }

    // Posts collection: Community Transmissions
    match /posts/{postId} {
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'poll'])
      );
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // Advocates collection: Professional Registry
    match /advocates/{advocateId} {
      allow get, list: if isAuthenticated();
      allow write: if isAuthenticated() && (advocateId == request.auth.uid || isAdmin());
    }
  }
}