rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Super Admin: Absolute authority check based on token email
    // Hardened to safely handle missing or uninitialized email tokens
    function isSuperAdmin() {
      return isAuthenticated() && 
             request.auth.token.email != null && (
        request.auth.token.email.lower() == 'enterspaceindia@gmail.com' || 
        request.auth.token.email.lower() == 'piyushkumrsingh23399@gmail.com' ||
        request.auth.token.email.lower() == 'nyayasahayakhelp@gmail.com'
      );
    }

    // General Admin check - Refined for robustness and fault-tolerance
    function isAdmin() {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // GLOBAL ADMIN OVERRIDE
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Users collection
    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create: if isAuthenticated() && userId == request.auth.uid;
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'poll'])
      );
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // Notifications collection - Optimized for List operations and Ownership checks
    match /notifications/{notificationId} {
      // Explicitly optimized read rule for query matching (list & get)
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }

    // Advocates collection
    match /advocates/{advocateId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (advocateId == request.auth.uid || isAdmin());
    }
  }
}