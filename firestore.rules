
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == 'enterspaceindia@gmail.com' || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    // Users collection
    match /users/{userId} {
      // Any authenticated user can read profiles (required for search/connect)
      allow get: if isAuthenticated();
      
      // Only designated admins can list all users
      allow list: if isAdmin();
      
      // Users can create their own profile
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      
      // Users can update their own profile, or admins can update ANY profile (for blocking/verification)
      allow update: if isOwner(userId) || isAdmin();
      
      // Only admin or owner can delete
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Posts collection
    match /posts {
      allow list: if isAuthenticated();
    }

    match /posts/{postId} {
      allow get: if isAuthenticated();
      
      // Author check for creation
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      
      // Allow updates by author, or specific fields (likes/poll) by any auth user
      allow update: if isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'poll'])
      );

      // Only author or admin can delete
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }
  }
}
