rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Robust admin check: checks auth token email, document email field, and isAdmin flag
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'enterspaceindia@gmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'enterspaceindia@gmail.com'))
      );
    }

    // Users collection: Central identity registry
    match /users/{userId} {
      // All authenticated users can look up profiles for verification
      allow get: if isAuthenticated();
      
      // Only system administrators can list the entire member registry
      allow list: if isAdmin();
      
      // Users can create their own profile during onboarding
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      
      // Users can update their own data; Admins have full update authority for all profiles
      // This is critical for the "Suspend/Block" and "Approve" features
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // Deletion allowed by owner or administrator
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Posts collection: Community feed
    match /posts {
      allow list: if isAuthenticated();
    }

    match /posts/{postId} {
      allow get: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      
      // Allow author updates or public reactions (likes/polls)
      allow update: if isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'poll'])
      );

      // Deletion restricted to author or admin
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }
  }
}