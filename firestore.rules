rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow get: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Posts collection
    match /posts {
      allow list: if isAuthenticated();
    }

    match /posts/{postId} {
      allow get: if isAuthenticated();
      
      // Author check for creation
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      
      // Allow updates by author, or specific fields (likes/poll) by any auth user
      allow update: if isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'poll'])
      );

      // Only author can delete
      allow delete: if isAuthenticated() && resource.data.authorUid == request.auth.uid;
    }
  }
}
