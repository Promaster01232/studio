rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'enterspaceindia@gmail.com';
    }

    // Users collection
    match /users/{userId} {
      allow get: if isAuthenticated();
      // Allow the designated admin to list all users for the Management Console
      allow list: if isAdmin();
      allow create: if isAuthenticated();
      // Allow user to update their own profile, or admin to update any profile (e.g. for blocking)
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Posts collection
    match /posts {
      allow list: if isAuthenticated();
    }

    match /posts/{postId} {
      allow get: if isAuthenticated();
      
      // Author check for creation
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      
      // Allow updates by author, or specific fields (likes/poll) by any auth user
      allow update: if isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'poll'])
      );

      // Only author or admin can delete
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }
  }
}
