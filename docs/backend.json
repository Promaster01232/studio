
{
    "entities": {
        "UserProfile": {
            "title": "User Profile",
            "description": "Represents a user's profile information.",
            "type": "object",
            "properties": {
                "uid": {
                    "type": "string",
                    "description": "The user's unique ID from Firebase Authentication."
                },
                "firstName": {
                    "type": "string",
                    "description": "The user's first name."
                },
                "lastName": {
                    "type": "string",
                    "description": "The user's last name."
                },
                "email": {
                    "type": "string",
                    "format": "email",
                    "description": "The user's email address."
                },
                "mobileNumber": {
                    "type": "string",
                    "description": "The user's mobile phone number."
                },
                "userType": {
                    "type": "string",
                    "enum": [
                        "citizen",
                        "lawyer",
                        "businessman",
                        "student"
                    ],
                    "description": "The type of user."
                },
                "photoURL": {
                    "type": "string",
                    "format": "uri",
                    "description": "The URL of the user's profile picture."
                },
                "isAdmin": {
                    "type": "boolean",
                    "description": "Whether the user has administrative privileges."
                },
                "isBlocked": {
                    "type": "boolean",
                    "description": "Whether the user's access has been suspended."
                },
                "securityStatus": {
                    "type": "string",
                    "enum": [
                        "verified",
                        "suspicious",
                        "flagged"
                    ],
                    "description": "The AI-determined security status of the account."
                },
                "flaggedAt": {
                    "type": "object",
                    "description": "Timestamp when the account was flagged by AI."
                },
                "flagReason": {
                    "type": "string",
                    "description": "Reason provided by AI for flagging the account."
                },
                "createdAt": {
                    "type": "object",
                    "description": "Timestamp when the user was created."
                }
            },
            "required": [
                "uid",
                "firstName",
                "lastName",
                "email",
                "userType"
            ]
        },
        "AdvocateProfile": {
            "title": "Advocate Profile",
            "description": "Professional credentials for legal directory.",
            "type": "object",
            "properties": {
                "uid": { "type": "string" },
                "name": { "type": "string" },
                "barId": { "type": "string" },
                "specialty": { "type": "string" },
                "isVerified": { "type": "boolean" },
                "isApproved": { "type": "boolean" },
                "courtName": { "type": "string" },
                "isBlocked": { "type": "boolean" }
            },
            "required": ["uid", "name", "barId"]
        }
    },
    "auth": {
        "providers": [
            "email-password",
            "google"
        ]
    },
    "firestore": {
        "/users/{userId}": {
            "schema": {
                "$ref": "#/entities/UserProfile"
            },
            "description": "Stores public information for each user."
        },
        "/advocates/{userId}": {
            "schema": {
                "$ref": "#/entities/AdvocateProfile"
            },
            "description": "Stores professional credentials for lawyers."
        }
    }
}
