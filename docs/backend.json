
{
    "entities": {
        "UserProfile": {
            "title": "User Profile",
            "description": "Represents a user's profile information.",
            "type": "object",
            "properties": {
                "uid": {
                    "type": "string",
                    "description": "The user's unique ID from Firebase Authentication."
                },
                "firstName": {
                    "type": "string"
                },
                "lastName": {
                    "type": "string"
                },
                "email": {
                    "type": "string",
                    "format": "email"
                },
                "mobileNumber": {
                    "type": "string"
                },
                "userType": {
                    "type": "string",
                    "enum": [
                        "citizen",
                        "businessman",
                        "student"
                    ]
                },
                "photoURL": {
                    "type": "string",
                    "format": "uri"
                },
                "isAdmin": {
                    "type": "boolean"
                },
                "isBlocked": {
                    "type": "boolean"
                },
                "aiUsageCount": {
                    "type": "number",
                    "description": "Number of AI forensic operations executed."
                },
                "subscriptionType": {
                    "type": "string",
                    "enum": ["free", "pro_20", "unlimited_monthly", "unlimited_yearly"],
                    "description": "The active statutory plan for the node."
                },
                "createdAt": {
                    "type": "object"
                }
            },
            "required": [
                "uid",
                "firstName",
                "lastName",
                "email",
                "userType"
            ]
        }
    },
    "auth": {
        "providers": [
            "email-password",
            "google"
        ]
    },
    "firestore": {
        "/users/{userId}": {
            "schema": {
                "$ref": "#/entities/UserProfile"
            }
        }
    }
}
