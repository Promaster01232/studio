
{
    "entities": {
        "UserProfile": {
            "title": "User Profile",
            "description": "Represents a user's profile information.",
            "type": "object",
            "properties": {
                "uid": {
                    "type": "string",
                    "description": "The user's unique ID from Firebase Authentication."
                },
                "firstName": {
                    "type": "string",
                    "description": "The user's first name."
                },
                "lastName": {
                    "type": "string",
                    "description": "The user's last name."
                },
                "email": {
                    "type": "string",
                    "format": "email",
                    "description": "The user's email address."
                },
                "mobileNumber": {
                    "type": "string",
                    "description": "The user's mobile phone number."
                },
                "userType": {
                    "type": "string",
                    "enum": [
                        "citizen",
                        "businessman",
                        "student"
                    ],
                    "description": "The type of user."
                },
                "photoURL": {
                    "type": "string",
                    "format": "uri",
                    "description": "The URL of the user's profile picture."
                },
                "isAdmin": {
                    "type": "boolean",
                    "description": "Whether the user has administrative privileges."
                },
                "isBlocked": {
                    "type": "boolean",
                    "description": "Whether the user's access has been suspended."
                },
                "securityStatus": {
                    "type": "string",
                    "enum": [
                        "verified",
                        "suspicious",
                        "flagged"
                    ],
                    "description": "The AI-determined security status of the account."
                },
                "flaggedAt": {
                    "type": "object",
                    "description": "Timestamp when the account was flagged by AI."
                },
                "flagReason": {
                    "type": "string",
                    "description": "Reason provided by AI for flagging the account."
                },
                "createdAt": {
                    "type": "object",
                    "description": "Timestamp when the user was created."
                }
            },
            "required": [
                "uid",
                "firstName",
                "lastName",
                "email",
                "userType"
            ]
        },
        "Notification": {
            "title": "Notification",
            "description": "Represents a user notification node.",
            "type": "object",
            "properties": {
                "userId": { "type": "string" },
                "type": { "type": "string", "enum": ["like", "admin_message", "system"] },
                "title": { "type": "string" },
                "description": { "type": "string" },
                "link": { "type": "string" },
                "isRead": { "type": "boolean" },
                "createdAt": { "type": "object" }
            },
            "required": ["userId", "type", "title", "description", "isRead", "createdAt"]
        }
    },
    "auth": {
        "providers": [
            "email-password",
            "google"
        ]
    },
    "firestore": {
        "/users/{userId}": {
            "schema": {
                "$ref": "#/entities/UserProfile"
            },
            "description": "Stores public information for each user."
        },
        "/notifications/{notificationId}": {
            "schema": {
                "$ref": "#/entities/Notification"
            },
            "description": "System and user-triggered notification nodes."
        }
    }
}
